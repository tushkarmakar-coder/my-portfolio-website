# Resend API configuration for portfolio contact form
# Get your API key from: https://resend.com/
RESEND_API_KEY=re_your_api_key_here

# Optional: Custom verified domain sending address
# If omitted, it defaults to: Portfolio Contact <onboarding@resend.dev>
# Once you verify your domain (e.g. brandnestagency.in), update this:
# RESEND_FROM_EMAIL=Tushar Karmakar <hello@brandnestagency.in>
